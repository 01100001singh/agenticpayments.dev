---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="No specimen at this address." path="/404">
  <div class="wrap reserved">
    <p class="eyebrow eyebrow--crimson">404</p>
    <h1>No specimen at this address.</h1>
    <p class="measure">
      Either it was never pinned, or it moved and left a proper record. Try
      <a href="/">the Counter</a> or the <a href="/lexicon/">Lexicon</a>.
    </p>
  </div>
</Base>

<style>
  .reserved { padding-top: 4rem; min-height: 40vh; }
  h1 { font-size: var(--fs-xxl); font-weight: 800; }
</style>
