---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PromptSidebar from '../../components/PromptSidebar.astro';
import CookedFrom from '../../components/CookedFrom.astro';

export async function getStaticPaths() {
  const entries = await getCollection('notebook', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const url = `https://agenticpayments.dev/notebook/${entry.id}`;
---

<Base title={d.title} description={d.summary ?? d.title} path={`/notebook/${entry.id}`}>
  <div class="wrap layout">
    <article>
      <header>
        <p class="eyebrow eyebrow--crimson">Notebook · essay</p>
        <h1>{d.title}</h1>
        <p class="date">{d.date.toISOString().slice(0, 10)}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
      <CookedFrom ids={d.cooked_from} />
    </article>
    <div class="side">
      <PromptSidebar
        title={d.title}
        url={url}
        prompts={d.prompts}
        payload={`${d.title} (essay)\n\n${(entry.body ?? '').trim()}`}
      />
    </div>
  </div>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: 3.5rem;
    padding-top: 2.4rem;
    align-items: start;
  }
  h1 { font-size: var(--fs-xl); font-weight: 800; margin: 0.3rem 0 0.2rem; max-width: var(--measure); }
  .date { font-family: var(--mono); font-size: var(--fs-xs); color: var(--faint); margin-bottom: 1.6rem; }
  .side { position: sticky; top: 1.5rem; }
  @media (max-width: 58rem) {
    .layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .side { position: static; }
  }
</style>
