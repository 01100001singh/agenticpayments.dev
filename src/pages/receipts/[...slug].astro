---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PromptSidebar from '../../components/PromptSidebar.astro';
import CookedFrom from '../../components/CookedFrom.astro';

export async function getStaticPaths() {
  const entries = await getCollection('receipts', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.data.number }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const url = `https://agenticpayments.dev/receipts/${d.number}`;
const hasBody = (entry.body ?? '').trim().length > 0;
---

<Base title={`Receipt #${d.number} — ${d.title}`} description={d.summary ?? d.title} path={`/receipts/${d.number}`}>
  <div class="wrap layout">
    <article>
      <header>
        <p class="eyebrow eyebrow--crimson">Receipt</p>
        <h1>{d.title}</h1>
      </header>

      <div class="receipt" role="figure" aria-label={`Receipt number ${d.number}`}>
        <p class="r-merchant">{d.merchant}</p>
        <p class="r-no">RECEIPT #{d.number} · {d.date.toISOString().slice(0, 10)}</p>
        <div class="r-rule" aria-hidden="true"></div>
        <table class="r-items">
          <tbody>
            {d.items.map((item) => (
              <tr>
                <td class="r-label">
                  {item.label}
                  {item.note && <span class="r-note">{item.note}</span>}
                </td>
                <td class="r-amount">{item.amount}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="r-rule" aria-hidden="true"></div>
        <p class="r-total">
          <span>{d.total.label}</span>
          <span>{d.total.amount}</span>
        </p>
        <div class="r-rule" aria-hidden="true"></div>
        <p class="r-footer">{d.footer}</p>
      </div>

      {hasBody && (
        <div class="prose">
          <Content />
        </div>
      )}

      <CookedFrom ids={d.cooked_from} />
    </article>
    <div class="side">
      <PromptSidebar
        title={`Receipt #${d.number} — ${d.title}`}
        url={url}
        prompts={d.prompts}
        payload={[
          `${d.merchant} — RECEIPT #${d.number}`,
          d.title,
          '',
          ...d.items.map((i) => `${i.label} ... ${i.amount}${i.note ? `  (${i.note})` : ''}`),
          `${d.total.label} ... ${d.total.amount}`,
          d.footer,
          '',
          (entry.body ?? '').trim(),
        ].join('\n')}
      />
    </div>
  </div>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: 3.5rem;
    padding-top: 2.4rem;
    align-items: start;
  }
  h1 { font-size: var(--fs-xl); font-weight: 800; margin: 0.3rem 0 1.6rem; max-width: var(--measure); }

  .receipt {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    background: var(--paper);
    border: 1px solid var(--rule2);
    box-shadow: 0 0 0 3px var(--paper), 0 0 0 4px var(--rule2);
    max-width: 27rem;
    padding: 1.6rem 1.5rem 1.3rem;
    margin: 0 0 2.2rem 3px;
  }
  .r-merchant { text-align: center; font-weight: 600; letter-spacing: 0.14em; margin: 0 0 0.2rem; }
  .r-no { text-align: center; font-size: var(--fs-xs); color: var(--faint); margin: 0 0 0.9rem; }
  .r-rule { border-top: 1px dashed var(--rule2); margin: 0.7rem 0; }
  .r-items { width: 100%; border-collapse: collapse; }
  .r-items td { border: 0; padding: 0.28rem 0; vertical-align: top; font-size: var(--fs-sm); }
  .r-label { padding-right: 1rem; }
  .r-note { display: block; font-size: var(--fs-xs); color: var(--faint); }
  .r-amount { text-align: right; white-space: nowrap; }
  .r-total { display: flex; justify-content: space-between; font-weight: 600; margin: 0; }
  .r-footer { text-align: center; color: var(--soft); margin: 0.9rem 0 0; }

  .side { position: sticky; top: 1.5rem; }
  @media (max-width: 58rem) {
    .layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .side { position: static; }
  }
</style>
