---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

const terms = (await getCollection('lexicon', (t) => !t.data.draft)).sort((a, b) =>
  a.data.term.localeCompare(b.data.term),
);
const rendered = await Promise.all(terms.map(async (t) => ({ t, Content: (await render(t)).Content })));

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'agenticpayments.dev Lexicon',
  url: 'https://agenticpayments.dev/lexicon/',
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.data.term,
    url: `https://agenticpayments.dev/lexicon/${t.id}/`,
  })),
};
---

<Base
  title="Lexicon"
  description="A working glossary of agentic payments: mandates, allowances, protocols, and the load-bearing words underneath them."
  path="/lexicon"
  jsonld={jsonld}
>
  <div class="wrap">
    <header class="page-head">
      <p class="eyebrow eyebrow--crimson">Lexicon</p>
      <h1>The words, pinned down</h1>
      <p class="lede measure">
        Definitions written to be load-bearing: every entry has a stable anchor, and the
        machine layer links entities here. If a word is doing quiet work in an argument,
        it should be on this page.
      </p>
    </header>

    <dl class="term-list">
      {rendered.map(({ t, Content }) => (
        <div class="term-row" id={t.id}>
          <dt>
            <a href={`/lexicon/${t.id}/`}>{t.data.term}</a>
            {t.data.aka.length > 0 && <span class="aka">also: {t.data.aka.join(', ')}</span>}
          </dt>
          <dd class="prose"><Content /></dd>
        </div>
      ))}
    </dl>
  </div>
</Base>

<style>
  .page-head { padding: 2.6rem 0 1.8rem; }
  h1 { font-size: var(--fs-xxl); font-weight: 800; }
  .lede { font-size: var(--fs-lg); color: var(--soft); }
  .term-list { margin: 0; border-top: 1px solid var(--ink); }
  .term-row {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: 2rem;
    border-bottom: 1px solid var(--rule);
    padding: 0.9rem 0;
  }
  dt { font-weight: 700; font-size: var(--fs-base); }
  dt a { color: var(--ink); }
  dt a:hover { color: var(--crimson); }
  .aka { display: block; font-family: var(--mono); font-size: var(--fs-xs); font-weight: 400; color: var(--faint); margin-top: 0.2rem; }
  dd { margin: 0; font-size: var(--fs-sm); color: var(--soft); max-width: 44rem; }
  dd :global(p) { margin-bottom: 0.5em; }
  dd :global(p:first-of-type) { font-size: var(--fs-sm); }
  @media (max-width: 50rem) {
    .term-row { grid-template-columns: 1fr; gap: 0.3rem; }
  }
</style>
