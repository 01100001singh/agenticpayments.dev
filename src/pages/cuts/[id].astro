---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Chips from '../../components/Chips.astro';
import MatrixFigure from '../../components/MatrixFigure.astro';
import PromptSidebar from '../../components/PromptSidebar.astro';
import { cutPath } from '../../lib/cutPath';

export async function getStaticPaths() {
  const cuts = await getCollection('cuts', (c) => !c.data.draft);
  return cuts.map((cut) => ({ params: { id: cut.data.slug ?? cut.data.id }, props: { cut } }));
}

const { cut } = Astro.props;
const d = cut.data;
const { Content } = await render(cut);
const url = `https://agenticpayments.dev${cutPath(d).replace(/\/$/, '')}`;
const dateStr = d.date.toISOString().slice(0, 10);
const validStr = d.valid_as_of.toISOString().slice(0, 10);
const staleStr = d.stale_after ? d.stale_after.toISOString().slice(0, 10) : null;
const preview = (cut.body ?? '').split(/\n\n+/)[0].replace(/[#*_>`[\]]/g, '').replace(/\n/g, ' ').slice(0, 155);

// Which authored Surfaces were cooked from this Cut
const surfaceKinds = ['bestiary', 'plates', 'parables', 'dialogues', 'receipts', 'journal', 'notebook'] as const;
const cookedInto: { title: string; href: string; kind: string }[] = [];
for (const kind of surfaceKinds) {
  for (const s of await getCollection(kind, (e: any) => !e.data.draft)) {
    if ((s.data as any).cooked_from?.includes(d.id)) {
      cookedInto.push({ title: (s.data as any).title, href: `/${kind}/${s.id}/`, kind });
    }
  }
}

const related = d.related.length
  ? await getCollection('cuts', (c) => d.related.includes(c.data.id) && !c.data.draft)
  : [];

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  datePublished: dateStr,
  dateModified: validStr,
  url,
  identifier: d.id,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  author: { '@type': 'Person', name: 'Ankit Singh', url: 'https://agenticpayments.dev/about/' },
  publisher: { '@type': 'Organization', name: 'agenticpayments.dev', url: 'https://agenticpayments.dev/' },
  keywords: d.tags.join(', '),
  encoding: {
    '@type': 'MediaObject',
    contentUrl: `https://agenticpayments.dev/cuts/${d.id}.stock.json`,
    encodingFormat: 'application/json',
  },
};
---

<Base title={d.title} description={`${preview}…`} path={cutPath(d).replace(/\/$/, '')} jsonld={jsonld}>
  <!-- Set the view before the article parses: no flash. Without JS the page
       stays in the full (remix) state and the toggle never appears. -->
  <script is:inline>
    (function () {
      var VIEWS = ['read', 'remix', 'raw'];
      var q = new URLSearchParams(location.search).get('view');
      var saved = null;
      try { saved = localStorage.getItem('agp-view'); } catch (e) {}
      var v = VIEWS.indexOf(q) >= 0 ? q : VIEWS.indexOf(saved) >= 0 ? saved : 'read';
      document.documentElement.dataset.view = v;
    })();
  </script>

  <div class="wrap">
    <div class="view-toggle" role="group" aria-label="Page view" hidden>
      <span class="vt-label">view</span>
      <button type="button" data-setview="read" title="Just the writing">read</button>
      <button type="button" data-setview="remix" title="The full specimen: prompts, record, lineage">remix</button>
      <button type="button" data-setview="raw" title="What an agent sees: the signed machine twin">raw</button>
    </div>
  </div>

  <div class="wrap layout">
    <article class="cut">
      <header>
        <div class="meta-row only-remix">
          <Chips type={d.type} era={d.era} />
          <span class="mono-meta">{d.id} · {dateStr}</span>
        </div>
        <h1>{d.title}</h1>
        <p class="plain-date only-read">{dateStr}</p>
      </header>

      <div class="prose cut-body">
        <Content />
      </div>

      {d.figure?.kind === 'matrix' && (
        <MatrixFigure cols={d.figure.cols} rows={d.figure.rows} caption={d.figure.caption} />
      )}

      {d.superseded_by && (
        <p class="supersede">
          ⚠ Superseded by <a href={`/cuts/${d.superseded_by}/`}>{d.superseded_by}</a>.
        </p>
      )}

      <footer class="colophon only-remix" aria-label="Specimen record">
        <p class="eyebrow">Specimen record</p>
        <dl>
          <div><dt>provenance</dt><dd>{d.provenance}</dd></div>
          <div><dt>valid as of</dt><dd>{validStr}</dd></div>
          {staleStr && <div><dt>stale after</dt><dd>{staleStr}</dd></div>}
          <div><dt>license</dt><dd>CC-BY-4.0 — take it, cite the URL</dd></div>
          <div><dt>tags</dt><dd>{d.tags.join(' · ')}</dd></div>
          <div>
            <dt>machine twin</dt>
            <dd><a href={`/cuts/${d.id}.stock.json`}>{d.id}.stock.json</a></dd>
          </div>
        </dl>

        {related.length > 0 && (
          <div class="related">
            <p class="eyebrow">Related cuts</p>
            <ul>
              {related.map((r) => (
                <li>
                  <a href={cutPath(r.data)}>{r.data.id}</a>
                  <span class="rel-title">— {r.data.title}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {cookedInto.length > 0 && (
          <div class="related">
            <p class="eyebrow">Cooked into</p>
            <ul>
              {cookedInto.map((s) => (
                <li>
                  <a href={s.href}>{s.title}</a>
                  <span class="rel-title">({s.kind})</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </footer>

      <footer class="read-license only-read">
        <p>
          Licensed CC-BY-4.0 — take it, cite this URL.
          <a href="?view=remix" data-setview="remix">Full record →</a>
        </p>
      </footer>
    </article>

    <div class="side only-remix">
      <PromptSidebar
        title={d.title}
        url={url}
        payload={`${d.title}\n(${d.id} · ${d.type} · era: ${d.era} · ${dateStr} · provenance: ${d.provenance})\n\n${(cut.body ?? '').trim()}`}
        stockUrl={`/cuts/${d.id}.stock.json`}
      />
    </div>
  </div>

  <div class="wrap raw-pane" aria-label="Machine twin">
    <p class="raw-head">
      /cuts/{d.id}.stock.json — the machine twin: same meaning, presentation deleted.
      <a href={`/cuts/${d.id}.stock.json`}>raw file</a> · <a href="/spine.jsonl">whole spine</a>
    </p>
    <pre class="raw-json" data-stock={`/cuts/${d.id}.stock.json`}>loading…</pre>
  </div>

  <script is:inline>
    (function () {
      var doc = document.documentElement;
      var bar = document.querySelector('.view-toggle');
      if (!bar) return;
      var filled = false;
      function fillRaw() {
        if (filled) return;
        filled = true;
        var pre = document.querySelector('.raw-json');
        fetch(pre.getAttribute('data-stock'))
          .then(function (r) { return r.json(); })
          .then(function (j) { pre.textContent = JSON.stringify(j, null, 2); })
          .catch(function () { pre.textContent = 'Could not load — open the raw file link above.'; });
      }
      function setView(v) {
        doc.dataset.view = v;
        try { localStorage.setItem('agp-view', v); } catch (e) {}
        var u = new URL(location.href);
        if (v === 'read') u.searchParams.delete('view');
        else u.searchParams.set('view', v);
        history.replaceState(null, '', u);
        bar.querySelectorAll('button').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.getAttribute('data-setview') === v));
        });
        if (v === 'raw') fillRaw();
      }
      bar.hidden = false;
      bar.querySelectorAll('button').forEach(function (b) {
        b.addEventListener('click', function () { setView(b.getAttribute('data-setview')); });
      });
      document.querySelectorAll('a[data-setview]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          e.preventDefault();
          setView(a.getAttribute('data-setview'));
        });
      });
      setView(doc.dataset.view || 'read');
    })();
  </script>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: 3.5rem;
    padding-top: 2.4rem;
    align-items: start;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }
  .mono-meta { font-family: var(--mono); font-size: var(--fs-xs); color: var(--faint); }
  h1 { font-size: var(--fs-xl); font-weight: 800; max-width: var(--measure); }
  .cut-body { margin-top: 1.2rem; }
  .supersede { color: var(--crimson); font-size: var(--fs-sm); }

  .colophon {
    margin-top: 2.8rem;
    border-top: 1px solid var(--ink);
    padding-top: 0.9rem;
    position: relative;
  }
  .colophon::before {
    content: '';
    position: absolute; top: 2px; left: 0; right: 0;
    border-top: 1px solid var(--rule2);
  }
  dl { margin: 0.7rem 0 0; display: grid; gap: 0.3rem; }
  dl > div { display: grid; grid-template-columns: 9rem 1fr; gap: 1rem; }
  dt {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--faint);
  }
  dd { margin: 0; font-size: var(--fs-sm); color: var(--soft); }
  .related { margin-top: 1.4rem; }
  .related ul { list-style: none; margin: 0.4rem 0 0; padding: 0; }
  .related li { font-size: var(--fs-sm); margin-bottom: 0.25rem; }
  .related li a { font-family: inherit; }
  .rel-title { color: var(--soft); }

  .side { position: sticky; top: 1.5rem; }
  @media (max-width: 58rem) {
    .layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .side { position: static; }
  }

  /* ---- Read / Remix / Raw ------------------------------------------------
     No data-view attribute (no JS) = the full remix page; the toggle stays
     hidden. read strips the ontology chrome; raw swaps in the machine twin. */
  .view-toggle {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
    padding-top: 1.6rem;
    font-family: var(--mono);
    font-size: var(--fs-xs);
  }
  .vt-label { color: var(--faint); text-transform: uppercase; letter-spacing: 0.09em; }
  .view-toggle button {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    text-transform: lowercase;
    background: none;
    border: 1px solid var(--rule2);
    padding: 0.2rem 0.65rem;
    color: var(--soft);
    cursor: pointer;
  }
  .view-toggle button:hover { color: var(--crimson); border-color: var(--crimson); }
  .view-toggle button[aria-pressed='true'] { color: var(--crimson); border-color: var(--crimson); }

  .only-read { display: none; }
  :global(html[data-view='read']) .only-read { display: block; }
  :global(html[data-view='read']) .only-remix { display: none; }
  :global(html[data-view='read']) .layout { grid-template-columns: minmax(0, 1fr); }

  .plain-date { font-family: var(--mono); font-size: var(--fs-xs); color: var(--faint); margin: 0.5rem 0 0; }
  .read-license {
    margin-top: 2.6rem;
    border-top: 1px solid var(--rule2);
    padding-top: 0.9rem;
    font-size: var(--fs-sm);
    color: var(--soft);
  }
  .read-license p { margin: 0; }

  .raw-pane { display: none; padding-top: 2.2rem; }
  :global(html[data-view='raw']) .raw-pane { display: block; }
  :global(html[data-view='raw']) .layout { display: none; }
  .raw-head { font-family: var(--mono); font-size: var(--fs-xs); color: var(--faint); margin: 0 0 0.8rem; }
  .raw-json {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    line-height: 1.55;
    color: var(--soft);
    background: var(--cream);
    border: 1px solid var(--rule2);
    padding: 1rem 1.1rem;
    overflow-x: auto;
    white-space: pre;
    margin: 0;
  }
</style>
