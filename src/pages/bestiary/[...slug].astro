---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PromptSidebar from '../../components/PromptSidebar.astro';
import CookedFrom from '../../components/CookedFrom.astro';
import SwitchEmblem from '../../components/emblems/SwitchEmblem.astro';
import MandatumEmblem from '../../components/emblems/MandatumEmblem.astro';

// Heraldic marks, by specimen. A mark is structure, not depiction —
// commissioned engravings can replace these via the `image` field.
const EMBLEMS: Record<string, any> = {
  'the-switch': SwitchEmblem,
  'the-mandatum': MandatumEmblem,
};

export async function getStaticPaths() {
  const entries = await getCollection('bestiary', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const url = `https://agenticpayments.dev/bestiary/${entry.id}`;

const FIELDS: [keyof typeof d.fields, string][] = [
  ['habitat', 'Habitat'],
  ['diet', 'Diet'],
  ['lifespan', 'Lifespan'],
  ['predators', 'Predators'],
  ['symbiotes', 'Symbiotes'],
  ['markings', 'Markings'],
  ['first_observed', 'First observed'],
];

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${d.title} (${d.latin})`,
  datePublished: d.date.toISOString().slice(0, 10),
  url,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  author: { '@type': 'Person', name: 'Ankit Singh' },
};
---

<Base title={d.title} description={d.summary ?? `${d.title} — ${d.latin}. A specimen from the bestiary of payment protocols.`} path={`/bestiary/${entry.id}`} jsonld={jsonld}>
  <div class="wrap layout">
    <article class="specimen">
      <header>
        <p class="eyebrow eyebrow--crimson">Bestiary · specimen</p>
        <h1>{d.title}</h1>
        <p class="latin">{d.latin}</p>
      </header>

      {d.image ? (
        <figure class="engraving">
          <img src={d.image} alt={`Engraving of ${d.title}`} loading="lazy" />
        </figure>
      ) : EMBLEMS[entry.id] ? (
        <figure class="engraving engraving--emblem">
          <span class="fig-label">Fig. — the mark of {d.title.toLowerCase()}</span>
          {(() => { const Emblem = EMBLEMS[entry.id]; return <Emblem />; })()}
        </figure>
      ) : (
        <div class="engraving engraving--fallback" aria-hidden="true">
          <span class="fig-label">Fig. — {d.title}</span>
          <span class="fallback-mark">{d.title.replace(/^The /, '').slice(0, 1)}</span>
          <span class="fallback-latin">{d.latin}</span>
          <span class="fallback-note">engraving pending; the specimen stands on its field record</span>
        </div>
      )}

      <p class="field-hint">
        Read it like a naturalist: <em>diet</em> is what sustains it; <em>predators</em> are
        what kill its kind. <a href="/bestiary/">Full legend →</a>
      </p>

      <dl class="field-list">
        {FIELDS.map(([key, label]) => (
          <div class="field-row">
            <dt>{label}</dt>
            <dd>{d.fields[key]}</dd>
          </div>
        ))}
      </dl>

      <div class="prose">
        <Content />
      </div>

      <CookedFrom ids={d.cooked_from} />
    </article>

    <div class="side">
      <PromptSidebar
        title={d.title}
        url={url}
        prompts={d.prompts}
        payload={[
          `${d.title} (${d.latin}) — a specimen from the bestiary of payment protocols`,
          '',
          ...FIELDS.map(([key, label]) => `${label.toUpperCase()}: ${d.fields[key]}`),
          '',
          (entry.body ?? '').trim(),
        ].join('\n')}
      />
    </div>
  </div>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: 3.5rem;
    padding-top: 2.4rem;
    align-items: start;
  }
  h1 { font-size: var(--fs-xxl); font-weight: 800; margin: 0.3rem 0 0; }
  .latin { font-style: italic; font-size: var(--fs-lg); color: var(--soft); margin: 0.1rem 0 1.6rem; }

  .engraving {
    margin: 0 0 1.8rem;
    border: 1px solid var(--ink);
    outline: 1px solid var(--rule2);
    outline-offset: 3px;
    background: var(--cream);
  }
  .engraving img { display: block; width: 100%; }
  .engraving--emblem {
    padding: 2.4rem 2rem 1.4rem;
    position: relative;
  }
  .engraving--emblem .fig-label {
    position: absolute;
    top: 0.7rem;
    left: 0.9rem;
    font-family: var(--mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--track-label);
    color: var(--faint);
  }
  .engraving--fallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 15rem;
    padding: 2.6rem 2rem 1.6rem;
    position: relative;
  }
  .fig-label {
    position: absolute;
    top: 0.7rem;
    left: 0.9rem;
    font-family: var(--mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--track-label);
    color: var(--faint);
  }
  .fallback-mark {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 8.5rem;
    line-height: 0.95;
    color: var(--rule2);
    text-transform: uppercase;
  }
  .fallback-latin {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-base);
    color: var(--soft);
  }
  .fallback-note {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    color: var(--faint);
    text-align: center;
    margin-top: 0.9rem;
  }

  .field-hint {
    font-size: var(--fs-sm);
    font-style: italic;
    color: var(--faint);
    margin: 0 0 0.6rem;
  }
  .field-hint a { font-family: var(--mono); font-style: normal; font-size: var(--fs-xs); }

  .field-list { margin: 0 0 2rem; border-top: 1px solid var(--ink); }
  .field-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.2rem;
    border-bottom: 1px solid var(--rule);
    padding: 0.55rem 0;
  }
  dt {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--track-label);
    color: var(--crimson);
    padding-top: 0.15rem;
  }
  dd { margin: 0; font-size: var(--fs-sm); }

  .side { position: sticky; top: 1.5rem; }
  @media (max-width: 58rem) {
    .layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .side { position: static; }
    .field-row { grid-template-columns: 1fr; gap: 0.15rem; }
  }
</style>
