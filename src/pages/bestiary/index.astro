---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('bestiary', (e) => !e.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base
  title="Bestiary"
  description="Payment protocols described as observed creatures: habitat, diet, lifespan, predators, symbiotes, markings."
  path="/bestiary"
>
  <div class="wrap">
    <header class="page-head">
      <p class="eyebrow eyebrow--crimson">Bestiary</p>
      <h1>Protocols, as creatures actually observed</h1>
      <p class="lede measure">
        A bestiary is an old form: a naturalist's catalog of creatures — their habits,
        their habitats, what they feed on, what hunts them. This one catalogs payment
        protocols the same way, because a spec records a protocol's promises, and a field
        record shows how it actually lives.
      </p>
      <div class="legend">
        <p class="eyebrow">Read the fields like a naturalist</p>
        <p class="legend-body">
          <span class="fld">habitat</span> — where it operates ·
          <span class="fld">diet</span> — what sustains it: volume, fees, subsidy, intent ·
          <span class="fld">lifespan</span> — how long its kind lasts ·
          <span class="fld">predators</span> — what kills it: regulation, concentration, starvation ·
          <span class="fld">symbiotes</span> — what it depends on, and feeds in return ·
          <span class="fld">markings</span> — how to recognize one in the wild
        </p>
      </div>
    </header>
    <div class="specimen-list">
      {entries.map((e) => (
        <a class="specimen-card" href={`/bestiary/${e.id}/`}>
          <span class="spec-name">{e.data.title}</span>
          <span class="spec-latin">{e.data.latin}</span>
          <span class="spec-habitat">{e.data.fields.habitat}</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .page-head { padding: 2.6rem 0 1.8rem; }
  h1 { font-size: var(--fs-xxl); font-weight: 800; max-width: 44rem; }
  .lede { font-size: var(--fs-lg); color: var(--soft); }
  .legend {
    background: var(--cream);
    border: 1px solid var(--rule2);
    padding: 0.9rem 1.1rem;
    max-width: 46rem;
    margin-top: 1.2rem;
  }
  .legend-body { font-size: var(--fs-sm); color: var(--soft); margin: 0.45rem 0 0; line-height: 1.75; }
  .fld {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--crimson);
  }
  .specimen-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr)); gap: 1.2rem; }
  .specimen-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border: 1px solid var(--rule2);
    background: var(--cream);
    padding: 1.1rem 1.2rem;
    color: var(--ink);
  }
  .specimen-card:hover { border-color: var(--crimson); text-decoration: none; }
  .spec-name { font-size: var(--fs-lg); font-weight: 700; }
  .spec-latin { font-style: italic; color: var(--soft); font-size: var(--fs-sm); }
  .spec-habitat { font-family: var(--mono); font-size: var(--fs-xs); color: var(--faint); margin-top: 0.5rem; }
</style>
